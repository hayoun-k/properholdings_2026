---
const moveInAmenities = [
  'Premium Egyptian cotton linens',
  'Fully equipped gourmet kitchen',
  'In-unit washer & dryer',
  'High-speed WiFi & smart TV',
  'Climate control & blackout shades',
  'Designer furniture & curated art',
  'Luxury bath amenities',
  'Personalized welcome package',
];

const extendedAmenities = [
  'Professional workspace & high-speed internet',
  'Concierge package services & storage',
  'Flexible check-in and check-out times',
  '24/7 dedicated concierge support',
  'Optional housekeeping packages',
  'Pet-friendly accommodations',
  'Included secure parking',
  'Neighborhood guides & insider tips',
];
---

<section id="rooms">
  <div class="section-header">
    <div class="section-tag">Living Experience</div>
    <h2>Refined comfort<br />for extended stays</h2>
    <p class="section-desc">
      Every residence is designed to feel like a refined home. Thoughtfully curated with premium
      finishes and everything needed for elegant, comfortable living.
    </p>
  </div>

  <div class="rooms-grid">
    <div class="room-visual">✨</div>
    <div class="room-content">
      <h3>Move-In Ready Elegance</h3>
      <p class="room-desc">
        No compromises. No assembly required. Every residence arrives perfectly appointed with
        curated furniture, Egyptian cotton linens, full kitchen, and luxury amenities. We handle the
        details so you experience the comfort.
      </p>
      <div class="amenities">
        {moveInAmenities.map((a) => <div class="amenity">{a}</div>)}
      </div>
    </div>
  </div>

  <div class="rooms-grid rooms-grid--reversed">
    <div class="room-content">
      <h3>Extended Stay Excellence</h3>
      <p class="room-desc">
        Designed for 30 days to a year or beyond. We understand that extended stays require more
        than housing—they require genuine hospitality. Dedicated workspace, flexible arrangements,
        and white-glove support.
      </p>
      <div class="amenities">
        {extendedAmenities.map((a) => <div class="amenity">{a}</div>)}
      </div>
    </div>
    <div class="room-visual">🏡</div>
  </div>
</section>

<style>
  #rooms {
    background: var(--white);
  }

  .rooms-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 100px;
    margin-top: 100px;
    align-items: center;
  }

  .rooms-grid--reversed {
    margin-top: 120px;
  }

  .room-visual {
    height: 520px;
    background: linear-gradient(135deg, #3a3a3a 0%, #2a2a2a 100%);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(201, 168, 76, 0.12);
    font-size: 130px;
    border: 1px solid #4a4a4a;
    position: relative;
    overflow: hidden;
  }

  .room-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse"><path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(201,168,76,0.03)" stroke-width="0.5"/></pattern></defs><rect width="100" height="100" fill="url(%23grid)"/></svg>');
  }

  .room-content h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 40px;
    color: var(--charcoal);
    margin-bottom: 28px;
    font-weight: 400;
  }

  .room-desc {
    font-size: 16px;
    color: var(--dark-gray);
    line-height: 1.95;
    margin-bottom: 36px;
  }

  .amenities {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 32px;
  }

  .amenity {
    font-size: 14px;
    color: var(--charcoal);
    padding: 16px 18px;
    background: var(--cream);
    border-radius: 2px;
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid #e0dcd8;
    transition: all 0.3s;
  }

  .amenity:hover {
    border-color: var(--charcoal);
    background: var(--off-white);
  }

  .amenity::before {
    content: '•';
    color: var(--gold);
    font-weight: 600;
    font-size: 18px;
    flex-shrink: 0;
  }

  @media (max-width: 1200px) {
    .rooms-grid { grid-template-columns: 1fr; gap: 60px; }
  }

  @media (max-width: 768px) {
    .rooms-grid { grid-template-columns: 1fr; }
  }
</style>

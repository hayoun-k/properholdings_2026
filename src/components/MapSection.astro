---

<section id="map">
  <div class="section-header">
    <div class="section-tag">Service Area</div>
    <h2>Excellence across<br />Los Angeles</h2>
    <p class="section-desc">Beverly Hills • West Hollywood • Mid City • Mid-Wilshire</p>
  </div>
  <div id="map-container"></div>
</section>

<style>
  #map {
    background: var(--white);
  }

  #map-container {
    width: 100%;
    height: 540px;
    border-radius: 2px;
    margin-top: 80px;
    background: linear-gradient(135deg, #dcdad6 0%, #c8c4c0 100%);
    border: 1px solid #d0ccc8;
  }
</style>

<script>
  function initMap() {
    const mapContainer = document.getElementById('map-container');
    if (!mapContainer) return;
    mapContainer.innerHTML = `
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg, #dcdad6 0%, #c8c4c0 100%);border-radius:2px;">
        <div style="text-align:center;color:#999;">
          <p style="font-size:18px;margin-bottom:8px; font-family: 'Cormorant Garamond', serif;">📍 Service Area Map</p>
          <p style="font-size:13px; font-family: 'Lora', serif;">Google Maps integration ready with API key</p>
        </div>
      </div>
    `;
  }

  window.addEventListener('load', initMap);
</script>

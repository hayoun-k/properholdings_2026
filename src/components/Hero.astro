---
---

<section id="hero">
  <div class="hero-content">
    <div class="hero-tag">Luxury Corporate Residences</div>
    <h1>Where sophistication<br />meets belonging.</h1>
    <p class="hero-desc">
      Curated residences in Los Angeles for discerning professionals. Experience
      genuine hospitality in every thoughtfully designed detail.
    </p>
    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">500+</div>
        <div class="stat-label">Guests Served</div>
      </div>
      <div class="stat">
        <div class="stat-num">98%</div>
        <div class="stat-label">Satisfaction</div>
      </div>
      <div class="stat">
        <div class="stat-num">4</div>
        <div class="stat-label">Prime Neighborhoods</div>
      </div>
    </div>
    <button
      class="btn-primary hero-cta"
      onclick="document.getElementById('properties').scrollIntoView({behavior:'smooth'})"
    >
      Book Now
    </button>
  </div>
  <div class="hero-visual">🏠</div>
</section>

<style>
  #hero {
    margin-top: 70px;
    padding: 0;
    background: linear-gradient(135deg, var(--white) 0%, var(--cream) 100%);
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    min-height: 95vh;
    position: relative;
  }

  .hero-content {
    flex: 1;
    padding: 120px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 700px;
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 32px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
  }

  .hero-desc {
    font-size: 17px;
    color: var(--dark-gray);
    line-height: 1.85;
    margin-bottom: 56px;
    max-width: 540px;
  }

  .hero-stats {
    display: flex;
    gap: 80px;
    margin-bottom: 56px;
  }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 300;
    color: var(--charcoal);
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    margin-top: 12px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
  }

  .hero-cta {
    display: inline-block;
    padding: 13px 40px;
    text-decoration: none;
    color: var(--charcoal);
    width: auto;
  }

  .hero-visual {
    flex: 1;
    background: linear-gradient(135deg, #3a3a3a 0%, #2a2a2a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(201, 168, 76, 0.1);
    font-size: 150px;
    position: relative;
    overflow: hidden;
  }

  .hero-visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse"><path d="M 20 0 L 0 0 0 20" fill="none" stroke="rgba(255,255,255,0.02)" stroke-width="0.5"/></pattern></defs><rect width="100" height="100" fill="url(%23grid)"/></svg>');
  }

  @media (max-width: 768px) {
    #hero { flex-direction: column; }
    .hero-content { padding: 60px 28px; }
    .hero-visual { height: 320px; }
    .hero-stats { flex-direction: column; gap: 40px; }
  }
</style>
